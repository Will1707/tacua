{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/approved-handoff/1.0.0/build-identity.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua immutable build identity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "media_type",
    "organization_id",
    "project_id",
    "build_id",
    "mobile",
    "backend",
    "sdk",
    "build_identity_digest"
  ],
  "properties": {
    "contract_version": { "const": "tacua.build-identity@1.0.0" },
    "media_type": { "const": "application/vnd.tacua.build-identity+json;version=1.0.0" },
    "organization_id": { "$ref": "#/$defs/id" },
    "project_id": { "$ref": "#/$defs/id" },
    "build_id": { "$ref": "#/$defs/id" },
    "mobile": { "$ref": "#/$defs/mobile" },
    "backend": {
      "oneOf": [
        { "$ref": "#/$defs/backendAvailable" },
        { "$ref": "#/$defs/backendUnavailable" }
      ]
    },
    "sdk": { "$ref": "#/$defs/sdk" },
    "build_identity_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$",
      "maxLength": 64
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sourceSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_id", "revision", "dirty"],
      "properties": {
        "repository_id": { "$ref": "#/$defs/id" },
        "revision": { "$ref": "#/$defs/sha" },
        "dirty": { "const": false }
      }
    },
    "mobile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "application_id",
        "app_version",
        "build_number",
        "distribution",
        "source",
        "native_binary_digest"
      ],
      "properties": {
        "platform": { "enum": ["ios", "android"] },
        "application_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{2,254}$"
        },
        "app_version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "build_number": { "type": "string", "minLength": 1, "maxLength": 64 },
        "distribution": {
          "enum": ["local-development", "internal", "testflight", "app-store", "play-internal", "play-store"]
        },
        "source": { "$ref": "#/$defs/sourceSnapshot" },
        "native_binary_digest": { "$ref": "#/$defs/digest" }
      }
    },
    "backendAvailable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability",
        "environment",
        "deployment_id",
        "image_digest",
        "deployed_at",
        "sources",
        "unavailable_reason"
      ],
      "properties": {
        "availability": { "const": "available" },
        "environment": { "type": "string", "minLength": 1, "maxLength": 64 },
        "deployment_id": { "$ref": "#/$defs/id" },
        "image_digest": { "$ref": "#/$defs/digest" },
        "deployed_at": { "$ref": "#/$defs/timestamp" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": { "$ref": "#/$defs/sourceSnapshot" }
        },
        "unavailable_reason": { "type": "null" }
      }
    },
    "backendUnavailable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "availability",
        "environment",
        "deployment_id",
        "image_digest",
        "deployed_at",
        "sources",
        "unavailable_reason"
      ],
      "properties": {
        "availability": { "const": "unavailable" },
        "environment": { "type": "string", "minLength": 1, "maxLength": 64 },
        "deployment_id": { "type": "null" },
        "image_digest": { "type": "null" },
        "deployed_at": { "type": "null" },
        "sources": { "type": "array", "maxItems": 0 },
        "unavailable_reason": {
          "enum": [
            "not_applicable",
            "not_deployed",
            "deployment_identity_unavailable",
            "connector_unavailable",
            "redacted_by_policy"
          ]
        }
      }
    },
    "sdk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_name",
        "package_version",
        "source_revision",
        "capture_schema_version",
        "configuration_digest"
      ],
      "properties": {
        "package_name": { "const": "@tacua/mobile-sdk" },
        "package_version": { "$ref": "#/$defs/semver" },
        "source_revision": { "$ref": "#/$defs/sha" },
        "capture_schema_version": { "type": "string", "minLength": 1, "maxLength": 128 },
        "configuration_digest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
