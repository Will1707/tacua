{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/approved-handoff/1.0.0/registry-assertion.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua candidate trusted registry assertion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "media_type",
    "assertion_id",
    "issuer_id",
    "organization_id",
    "project_id",
    "ticket_id",
    "ticket_version",
    "current_handoff_digest",
    "registry_revision",
    "authorized_sources",
    "issued_at",
    "expires_at",
    "signature"
  ],
  "properties": {
    "contract_version": { "const": "tacua.registry-assertion@1.0.0" },
    "media_type": { "const": "application/vnd.tacua.registry-assertion+json;version=1.0.0" },
    "assertion_id": { "$ref": "#/$defs/id" },
    "issuer_id": { "$ref": "#/$defs/id" },
    "organization_id": { "$ref": "#/$defs/id" },
    "project_id": { "$ref": "#/$defs/id" },
    "ticket_id": { "$ref": "#/$defs/id" },
    "ticket_version": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "current_handoff_digest": { "$ref": "#/$defs/digest" },
    "registry_revision": { "$ref": "#/$defs/id" },
    "authorized_sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/source" }
    },
    "issued_at": { "$ref": "#/$defs/timestamp" },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component", "source_id", "snapshot_revision"],
      "properties": {
        "component": { "enum": ["mobile_sdk", "backend", "repository", "sentry", "posthog"] },
        "source_id": { "$ref": "#/$defs/id" },
        "snapshot_revision": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": { "const": "hmac-sha256" },
        "key_id": { "$ref": "#/$defs/id" },
        "value": {
          "type": "string",
          "pattern": "^hmac-sha256:[a-f0-9]{64}$"
        }
      }
    }
  }
}
