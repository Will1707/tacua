{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/approved-handoff/1.0.0/evidence-manifest.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua evidence manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "media_type",
    "organization_id",
    "project_id",
    "session_id",
    "manifest_id",
    "items",
    "evidence_manifest_digest"
  ],
  "properties": {
    "contract_version": { "const": "tacua.evidence-manifest@1.0.0" },
    "media_type": { "const": "application/vnd.tacua.evidence-manifest+json;version=1.0.0" },
    "organization_id": { "$ref": "#/$defs/id" },
    "project_id": { "$ref": "#/$defs/id" },
    "session_id": { "$ref": "#/$defs/id" },
    "manifest_id": { "$ref": "#/$defs/id" },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "evidence-item.schema.json" }
    },
    "evidence_manifest_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
