{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/approved-handoff/1.0.0/execution-revocations.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua execution assertion revocations",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "media_type",
    "list_id",
    "issuer_id",
    "revision",
    "issued_at",
    "expires_at",
    "revoked_assertion_ids",
    "revoked_nonces",
    "revoked_key_ids",
    "signature"
  ],
  "properties": {
    "contract_version": { "const": "tacua.execution-revocations@1.0.0" },
    "media_type": { "const": "application/vnd.tacua.execution-revocations+json;version=1.0.0" },
    "list_id": { "$ref": "#/$defs/id" },
    "issuer_id": { "$ref": "#/$defs/id" },
    "revision": { "$ref": "#/$defs/id" },
    "issued_at": { "$ref": "#/$defs/timestamp" },
    "expires_at": { "$ref": "#/$defs/timestamp" },
    "revoked_assertion_ids": {
      "type": "array",
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "revoked_nonces": {
      "type": "array",
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Za-z0-9_-]{22,128}$" }
    },
    "revoked_key_ids": {
      "type": "array",
      "maxItems": 100,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,63}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "value"],
      "properties": {
        "algorithm": { "const": "hmac-sha256" },
        "key_id": { "$ref": "#/$defs/id" },
        "value": { "type": "string", "pattern": "^hmac-sha256:[a-f0-9]{64}$" }
      }
    }
  }
}
