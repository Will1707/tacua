{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/sdk-backend/1.0.0/common.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua SDK/backend protocol common definitions",
  "type": "object",
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "protocolVersion": { "const": "tacua.sdk-backend@1.0.0" },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{2,63}$" },
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "shortText": { "type": "string", "minLength": 1, "maxLength": 512 },
    "versionText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._+/-]+$"
    },
    "nullableShortText": {
      "oneOf": [
        { "$ref": "#/$defs/shortText" },
        { "type": "null" }
      ]
    },
    "secret": {
      "type": "string",
      "minLength": 43,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9_-]+$",
      "writeOnly": true
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_type", "size_bytes", "content_digest"],
      "properties": {
        "content_type": {
          "enum": [
            "application/json",
            "application/vnd.tacua.diagnostic-envelope+json;version=1.0.0",
            "video/mp4",
            "video/quicktime"
          ]
        },
        "size_bytes": { "type": "integer", "minimum": 1, "maximum": 1073741824 },
        "content_digest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
