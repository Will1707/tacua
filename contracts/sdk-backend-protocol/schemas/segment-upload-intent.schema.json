{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/sdk-backend/1.0.0/segment-upload-intent.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua idempotent segment-upload intent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "message_type",
    "upload_id",
    "session_id",
    "scope_digest",
    "sequence",
    "segment_id",
    "transport",
    "sidecar_digest",
    "intent_digest"
  ],
  "properties": {
    "protocol_version": { "$ref": "common.schema.json#/$defs/protocolVersion" },
    "message_type": { "const": "segment_upload_intent" },
    "upload_id": { "$ref": "common.schema.json#/$defs/id" },
    "session_id": { "$ref": "common.schema.json#/$defs/id" },
    "scope_digest": { "$ref": "common.schema.json#/$defs/digest" },
    "sequence": { "type": "integer", "minimum": 0, "maximum": 2047 },
    "segment_id": { "$ref": "common.schema.json#/$defs/id" },
    "transport": { "$ref": "common.schema.json#/$defs/transport" },
    "sidecar_digest": { "$ref": "common.schema.json#/$defs/digest" },
    "intent_digest": { "$ref": "common.schema.json#/$defs/digest" }
  }
}
