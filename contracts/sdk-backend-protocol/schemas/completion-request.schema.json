{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/sdk-backend/1.0.0/completion-request.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua idempotent capture-completion request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "message_type",
    "completion_id",
    "session_id",
    "scope_digest",
    "credential_id",
    "capture_manifest",
    "segment_receipts",
    "diagnostic_receipts",
    "requested_at",
    "request_digest"
  ],
  "properties": {
    "protocol_version": { "$ref": "common.schema.json#/$defs/protocolVersion" },
    "message_type": { "const": "completion_request" },
    "completion_id": { "$ref": "common.schema.json#/$defs/id" },
    "session_id": { "$ref": "common.schema.json#/$defs/id" },
    "scope_digest": { "$ref": "common.schema.json#/$defs/digest" },
    "credential_id": { "$ref": "common.schema.json#/$defs/id" },
    "capture_manifest": {
      "$ref": "../../runtime/schemas/capture-upload-manifest.schema.json"
    },
    "segment_receipts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2048,
      "items": { "$ref": "segment-upload-receipt.schema.json" }
    },
    "diagnostic_receipts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2048,
      "items": { "$ref": "diagnostic-upload-receipt.schema.json" }
    },
    "requested_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "request_digest": { "$ref": "common.schema.json#/$defs/digest" }
  }
}
