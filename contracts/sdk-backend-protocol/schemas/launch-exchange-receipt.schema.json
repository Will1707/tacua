{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/sdk-backend/1.0.0/launch-exchange-receipt.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua launch-code exchange receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "message_type",
    "exchange_kind",
    "exchange_id",
    "request_digest",
    "session_id",
    "session_state",
    "scope",
    "credential",
    "previous_credential_revocation",
    "received_at",
    "issued_at",
    "exchange_receipt_digest"
  ],
  "properties": {
    "protocol_version": { "$ref": "common.schema.json#/$defs/protocolVersion" },
    "message_type": { "const": "launch_exchange_receipt" },
    "exchange_kind": { "enum": ["start_session", "resume_session"] },
    "exchange_id": { "$ref": "common.schema.json#/$defs/id" },
    "request_digest": { "$ref": "common.schema.json#/$defs/digest" },
    "session_id": { "$ref": "common.schema.json#/$defs/id" },
    "session_state": { "enum": ["receiving", "completed"] },
    "scope": { "$ref": "capture-scope.schema.json" },
    "credential": { "$ref": "#/$defs/credential" },
    "previous_credential_revocation": {
      "oneOf": [
        { "$ref": "#/$defs/previousCredentialRevocation" },
        { "type": "null" }
      ]
    },
    "received_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "issued_at": { "$ref": "common.schema.json#/$defs/timestamp" },
    "exchange_receipt_digest": { "$ref": "common.schema.json#/$defs/digest" }
  },
  "allOf": [
    {
      "if": { "properties": { "exchange_kind": { "const": "start_session" } } },
      "then": { "properties": { "previous_credential_revocation": { "type": "null" } } }
    },
    {
      "if": { "properties": { "exchange_kind": { "const": "resume_session" } } },
      "then": {
        "properties": {
          "previous_credential_revocation": { "$ref": "#/$defs/previousCredentialRevocation" }
        }
      }
    },
    {
      "if": { "properties": { "session_state": { "const": "receiving" } } },
      "then": {
        "properties": {
          "credential": {
            "properties": {
              "state": { "const": "active" },
              "replay_completion_id": { "type": "null" }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "session_state": { "const": "completed" } } },
      "then": {
        "properties": {
          "exchange_kind": { "const": "resume_session" },
          "credential": {
            "properties": {
              "state": { "const": "completion_replay_or_delete_only" },
              "replay_completion_id": { "$ref": "common.schema.json#/$defs/id" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credential_id", "authentication_scheme", "state", "replay_completion_id", "expires_at"],
      "properties": {
        "credential_id": { "$ref": "common.schema.json#/$defs/id" },
        "authentication_scheme": { "const": "Bearer" },
        "state": { "enum": ["active", "completion_replay_or_delete_only"] },
        "replay_completion_id": {
          "oneOf": [
            { "$ref": "common.schema.json#/$defs/id" },
            { "type": "null" }
          ]
        },
        "expires_at": { "$ref": "common.schema.json#/$defs/timestamp" }
      }
    },
    "previousCredentialRevocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["credential_id", "state", "revoked_at"],
      "properties": {
        "credential_id": { "$ref": "common.schema.json#/$defs/id" },
        "state": { "const": "revoked" },
        "revoked_at": { "$ref": "common.schema.json#/$defs/timestamp" }
      }
    }
  }
}
