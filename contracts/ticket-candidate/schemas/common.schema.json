{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/ticket-candidate/1.0.0/common.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua ticket-candidate common definitions",
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "boundedText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "shortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "nullableText": {
      "oneOf": [
        { "$ref": "#/$defs/boundedText" },
        { "type": "null" }
      ]
    },
    "nullableTimestamp": {
      "oneOf": [
        { "$ref": "#/$defs/timestamp" },
        { "type": "null" }
      ]
    },
    "nullableDigest": {
      "oneOf": [
        { "$ref": "#/$defs/digest" },
        { "type": "null" }
      ]
    },
    "nullableId": {
      "oneOf": [
        { "$ref": "#/$defs/id" },
        { "type": "null" }
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_type", "actor_id"],
      "properties": {
        "actor_type": { "enum": ["system", "human"] },
        "actor_id": { "$ref": "#/$defs/id" }
      }
    }
  }
}
