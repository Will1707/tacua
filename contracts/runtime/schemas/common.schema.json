{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tacua.invalid/schemas/runtime/1.0.0/common.schema.json",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "title": "Tacua runtime contract common definitions",
  "type": "object",
  "additionalProperties": false,
  "properties": {},
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{2,63}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "nullableTimestamp": {
      "oneOf": [
        { "$ref": "#/$defs/timestamp" },
        { "type": "null" }
      ]
    },
    "nullableDigest": {
      "oneOf": [
        { "$ref": "#/$defs/digest" },
        { "type": "null" }
      ]
    },
    "boundedText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "shortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "nullableText": {
      "oneOf": [
        { "$ref": "#/$defs/boundedText" },
        { "type": "null" }
      ]
    },
    "timeRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_ms", "end_ms", "clock"],
      "properties": {
        "start_ms": { "type": "integer", "minimum": 0, "maximum": 1800000 },
        "end_ms": { "type": "integer", "minimum": 0, "maximum": 1800000 },
        "clock": { "const": "session_monotonic" }
      }
    },
    "unavailable": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "detail"],
      "properties": {
        "reason": {
          "enum": [
            "capture_gap",
            "collection_disabled",
            "permission_denied",
            "provider_unavailable",
            "connector_revoked",
            "redacted_by_policy",
            "not_configured",
            "outside_retention",
            "correlation_missing",
            "upload_failed",
            "unknown"
          ]
        },
        "detail": { "$ref": "#/$defs/shortText" }
      }
    },
    "redaction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy_version", "applied", "removed_field_count"],
      "properties": {
        "policy_version": { "type": "string", "minLength": 1, "maxLength": 128 },
        "applied": { "type": "boolean" },
        "removed_field_count": { "type": "integer", "minimum": 0, "maximum": 1000000 }
      }
    }
  }
}
