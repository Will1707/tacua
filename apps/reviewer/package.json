{
  "name": "@tacua/reviewer-app",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "export:ios": "expo export --platform ios",
    "export:web": "expo export --platform web",
    "test": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --test src/approved-handoff/*.test.mjs src/api/*.test.mjs src/candidates/*.test.mjs src/components/*.render.test.cjs src/config/*.test.mjs src/providers/*.render.test.cjs src/theme/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.17",
    "expo": "~56.0.12",
    "expo-crypto": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-linking": "~56.0.15",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.22",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-modules-commonjs": "7.29.7",
    "@babel/plugin-transform-react-jsx": "7.29.7",
    "@babel/plugin-transform-typescript": "7.29.7",
    "@types/react": "~19.2.2",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  }
}
