{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "expo": ["./node_modules/expo"],
      "expo-modules-core": ["./node_modules/expo-modules-core"]
    },
    "strict": true,
    "noEmit": true
  },
  "include": ["index.ts", "src/**/*.ts", "src/**/*.tsx"]
}
