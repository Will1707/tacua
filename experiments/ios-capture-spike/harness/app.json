{
  "expo": {
    "name": "Tacua Capture Lab",
    "slug": "tacua-capture-lab",
    "scheme": "tacua-capture-lab",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.tacua.capturelab.acceptance",
      "buildNumber": "1",
      "deploymentTarget": "17.0",
      "supportsTablet": false,
      "infoPlist": {
        "TacuaCaptureFaultInjectionEnabled": true,
        "TacuaLocalHarnessRetentionBypassEnabled": true
      }
    },
    "plugins": [
      "expo-dev-client",
      [
        "@tacua/mobile-sdk",
        {
          "allowInsecureLoopback": true,
          "backendOrigin": "http://127.0.0.1:8080",
          "buildVariant": "development",
          "captureEnabled": true,
          "distribution": "local",
          "launchScheme": "tacua-capture-lab",
          "sdkProfilePath": "./tacua-sdk-profile.json"
        }
      ]
    ],
    "extra": {
      "tacuaExperiment": "EXP-001"
    }
  }
}
