            "local_model": { "decision": "allow_after_irreversible_transformation", "operations": ["prompt-build"], "transform": "provider_payload_filter" },
            "external_model": { "decision": "require_explicit_project_reviewer_approval", "operations": ["prompt-build"], "transform": "provider_payload_filter" },
            "reviewer_ui": { "decision": "require_explicit_project_reviewer_approval", "operations": ["retrieve"], "transform": "bounded_provider_excerpt" }
          }
        },
        {
          "path": "provider_reference",
          "classification": "metadata_reference",
          "rules": {
            "ingest_store": { "decision": "allow_metadata_reference_only", "operations": ["persist", "retrieve", "retain", "delete"] },
            "processing_worker": { "decision": "allow_metadata_reference_only", "operations": ["retrieve"] },
            "connector_broker": { "decision": "allow_metadata_reference_only", "operations": ["tool-call"] },
            "local_model": { "decision": "allow_metadata_reference_only", "operations": ["prompt-build"] },
            "external_model": { "decision": "require_explicit_project_reviewer_approval", "operations": ["prompt-build"] },
            "reviewer_ui": { "decision": "allow_metadata_reference_only", "operations": ["retrieve"] },
            "approved_handoff": { "decision": "allow_metadata_reference_only", "operations": ["render-export"] },
            "audit_log": { "decision": "allow_metadata_reference_only", "operations": ["persist", "retain", "delete"] }
          }
        }
      ]
