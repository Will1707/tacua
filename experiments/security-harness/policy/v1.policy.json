            "local_model": { "decision": "allow_after_irreversible_transformation", "operations": ["prompt-build"], "transform": "source_secret_redaction" },
            "external_model": { "decision": "require_explicit_project_reviewer_approval", "operations": ["prompt-build"], "transform": "source_secret_redaction" },
            "reviewer_ui": { "decision": "require_explicit_project_reviewer_approval", "operations": ["retrieve"], "transform": "bounded_source_excerpt" }
          }
        },
        {
          "path": "source_reference",
          "classification": "metadata_reference",
          "rules": {
            "ingest_store": { "decision": "allow_metadata_reference_only", "operations": ["persist", "retrieve", "retain", "delete"] },
            "processing_worker": { "decision": "allow_metadata_reference_only", "operations": ["retrieve"] },
            "connector_broker": { "decision": "allow_metadata_reference_only", "operations": ["tool-call"] },
            "local_model": { "decision": "allow_metadata_reference_only", "operations": ["prompt-build"] },
