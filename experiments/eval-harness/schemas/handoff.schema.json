{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "SPDX-License-Identifier: Apache-2.0",
  "$id": "https://tacua.invalid/schemas/handoff/1.0.0",
  "title": "Tacua coding-agent handoff concept fixture",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "handoff_id", "status", "build_identity", "title", "observed_facts", "expected_behavior", "inferences", "unknowns", "provenance", "reproduction_steps", "acceptance_criteria", "suggested_verification", "authority"],
  "properties": {
    "contract_version": {"const": "tacua.handoff-concept@1.0.0"},
    "handoff_id": {"type": "string"},
    "status": {"const": "synthetic_concept_fixture"},
    "build_identity": {"type": "object"},
    "title": {"type": "string"},
    "observed_facts": {"type": "array", "items": {"type": "object"}},
    "expected_behavior": {"type": "array", "items": {"type": "object"}},
    "inferences": {"type": "array", "items": {"type": "object"}},
    "unknowns": {"type": "array", "items": {"type": "string"}},
    "provenance": {"type": "array", "items": {"type": "object"}},
    "reproduction_steps": {"type": "array", "items": {"type": "string"}},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "suggested_verification": {"type": "array", "items": {"type": "string"}},
    "authority": {
      "type": "object",
      "required": ["repository_access", "external_writes", "merge", "deploy"],
      "properties": {
        "repository_access": {"const": "read_only_until_isolated_trial"},
        "external_writes": {"const": false},
        "merge": {"const": false},
        "deploy": {"const": false}
      }
    }
  }
}
